#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

REMOTE="${REMOTE_SSH:-root@192.168.33.100}"
CONFIGURATION="${CONFIGURATION:-Debug}"
TARGET_FRAMEWORK="${TARGET_FRAMEWORK:-net8.0}"
TOKENIZER_BUNDLE="${TOKENIZER_BUNDLE:-single-rid}"
TOKENIZER_RID="${TOKENIZER_RID:-linux-x64}"
LOCAL_DLL="${LOCAL_DLL:-}"
REMOTE_DIR="${REMOTE_DIR:-/opt/emby/config/plugins}"
COMPOSE_DIR="${COMPOSE_DIR:-/opt/emby}"
NO_BUILD="${NO_BUILD:-0}"

print_usage() {
  cat <<EOF
Usage:
  bash Scripts/restart [Debug|Release]
  bash Scripts/restart --configuration Release

Options:
  --remote <ssh-target>       SSH target. Default: ${REMOTE}
  --configuration <name>      Build configuration. Default: ${CONFIGURATION}
  --target-framework <tfm>    Target framework. Default: ${TARGET_FRAMEWORK}
  --tokenizer-bundle <value>  Kept for default DLL path compatibility. Default: ${TOKENIZER_BUNDLE}
  --tokenizer-rid <rid>       Kept for default DLL path compatibility. Default: ${TOKENIZER_RID}
  --local-dll <path>          Built DLL path to copy.
  --no-build                  Skip local build and upload the existing DLL.
  --remote-dir <path>         Remote plugin directory. Default: ${REMOTE_DIR}
  --compose-dir <path>        Remote compose directory. Default: ${COMPOSE_DIR}
  -h, --help                  Show this help.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    Debug|Release)
      CONFIGURATION="$1"
      shift
      ;;
    --remote)
      REMOTE="${2:?missing value for --remote}"
      shift 2
      ;;
    --configuration)
      CONFIGURATION="${2:?missing value for --configuration}"
      shift 2
      ;;
    --target-framework)
      TARGET_FRAMEWORK="${2:?missing value for --target-framework}"
      shift 2
      ;;
    --tokenizer-bundle)
      TOKENIZER_BUNDLE="${2:?missing value for --tokenizer-bundle}"
      shift 2
      ;;
    --tokenizer-rid)
      TOKENIZER_RID="${2:?missing value for --tokenizer-rid}"
      shift 2
      ;;
    --local-dll)
      LOCAL_DLL="${2:?missing value for --local-dll}"
      shift 2
      ;;
    --no-build)
      NO_BUILD=1
      shift
      ;;
    --remote-dir)
      REMOTE_DIR="${2:?missing value for --remote-dir}"
      shift 2
      ;;
    --compose-dir)
      COMPOSE_DIR="${2:?missing value for --compose-dir}"
      shift 2
      ;;
    -h|--help)
      print_usage
      exit 0
      ;;
    *)
      echo "Error: unknown option: $1" >&2
      print_usage >&2
      exit 1
      ;;
  esac
done

if [ -z "${LOCAL_DLL}" ]; then
  LOCAL_DLL="${PROJECT_DIR}/Build/bin/${CONFIGURATION}/${TARGET_FRAMEWORK}/MediaInfoKeeper.dll"
fi

if [ "${NO_BUILD}" != "1" ]; then
  dotnet build "${PROJECT_DIR}/MediaInfoKeeper.csproj" -c "${CONFIGURATION}" -f "${TARGET_FRAMEWORK}" \
    --no-restore \
    /p:TokenizerBundle="${TOKENIZER_BUNDLE}" \
    /p:TokenizerRid="${TOKENIZER_RID}"
fi

if [ ! -f "${LOCAL_DLL}" ]; then
  echo "Error: built DLL not found: ${LOCAL_DLL}" >&2
  exit 1
fi

echo "Uploading ${CONFIGURATION}/${TARGET_FRAMEWORK}: ${LOCAL_DLL} -> ${REMOTE}:${REMOTE_DIR}/"
scp "${LOCAL_DLL}" "${REMOTE}:${REMOTE_DIR}/"
ssh "${REMOTE}" "cd \"${COMPOSE_DIR}\" && docker compose restart"
